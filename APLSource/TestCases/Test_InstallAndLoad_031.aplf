 rвҶҗTest_InstallAndLoad_031(stopFlag batchFlag);вҺ•TRAP;rc;msg;zipFilename;toBeDeleted;res
 ;dir;src;body;cfg;installFolder;src2;src3;reg
вҚқ A package that depend on another package that has several functions
 вҺ•TRAPвҶҗ(999 'C' '. вҚқ Deliberate error')(0 'N')
 rвҶҗT._Failed

 #.вҺ•EX TC.GetTatinRootSpace'#'
 #.вҺ•SHADOW'TEMP' вӢ„ 'TEMP'#.вҺ•NS''        вҚқ Used to load stuff into
 #.вҺ•SHADOW'TEMP2' вӢ„ 'TEMP2'#.вҺ•NS''      вҚқ Used to create a package
 dirвҶҗвҲҶGetTempDir вҚ¬
 (src reg)вҶҗ(вҠӮdir,'/'),ВЁ'src' 'reg'
 src2вҶҗsrc,'/Example-Constants-0.1.0/'
 src3вҶҗsrc,'/Example-MyMath-0.2.0/'
 F.MkDir reg
 F.MkDir src2 src3,ВЁвҠӮ'/APLSource'
 toBeDeletedвҶҗ''

 TC.Reg.CreateRegistry reg
 TC.MyUserSettings.AddRegistry'[local2]',reg

 bodyвҶҗ':Class Constants' 'вҲҮrвҶҗPI' ':Access Public Shared' 'rвҶҗ3.14' 'вҲҮ' ':EndClass'
 (вҠӮbody)F.NPUT src2,'/APLSource/Constants.aplc'
 cfgвҶҗTC.InitPackageConfig вҚ¬
 cfg.(group name version)вҶҗ'Example' 'Constants' '0.1.0'
 cfg.sourceвҶҗ'APLSource'
 cfg.os_winвҶҗ1
 TC.WritePackageConfigFile src2 cfg
 (rc msg zipFilename)вҶҗTC.PublishPackage src2 reg
 toBeDeleted,вҶҗвҠӮzipFilename
 Assert 200=rc

 cfgвҶҗTC.InitPackageConfig вҚ¬
 cfg.(group name version)вҶҗ'Example' 'MyMath' '0.2.0'
 cfg.sourceвҶҗ'APLSource'
 cfg.os_winвҶҗ1
 TC.WritePackageConfigFile src3 cfg
 src3 TC.Dependencies.Add'Example-Constants-0.1.0'
 Assert' '=1вҶ‘0вҚҙ#.TEMP2.вҺ•FX'rвҶҗx Times y' 'rвҶҗConstants.PIГ— xГ—y'
 Assert' '=1вҶ‘0вҚҙ#.TEMP2.вҺ•FX'rвҶҗTotal x' 'rвҶҗ+/x'
 Assert' '=1вҶ‘0вҚҙ#.TEMP2.вҺ•FX'rвҶҗx Power y' 'rвҶҗx*y'
 Assert' '=1вҶ‘0вҚҙ#.TEMP2.вҺ•FX'rвҶҗPublic' 'rвҶҗ''Total'' ''Power'''
 resвҶҗвҺ•SE.Link.Create #.TEMP2(src3,cfg.source)
 Assert{(вҲЁ/'Linked: #.TEMP2 вҶ’'вҚ·вҚө)вҲЁ(вҲЁ/'Linked: #.TEMP2 вҶҗвҶ’'вҚ·вҚө)}вҲҠres

 (rc msg zipFilename)вҶҗTC.PublishPackage src3 reg
 toBeDeleted,вҶҗвҠӮzipFilename
 Assert 200=rc

 installFolderвҶҗвҲҶGetTempDir'/Tatin_AppPackages'
 resвҶҗTC.InstallPackages('Example-MyMath-0.2.0')installFolder
 вҶ’T.GoToTidyUp(вҲҠres)вүў'Example-MyMath-0.2.0'

 вҶ’T.GoToTidyUp 2вү вүўF.ListDirs installFolder
 вҶ’T.GoToTidyUp 2вү вүў'NOTICE.md'{вҚө/вҚЁвҚәвҲҳвүўВЁ(-вүўвҚә)вҶ‘ВЁвҚө}F.ListFiles installFolder
 вҶ’T.GoToTidyUp(,вҠӮ'Example-MyMath-0.2.0')вүўTC.Dependencies.Get installFolder

 {}TC.LoadDependencies installFolder #.TEMP
 вҶ’T.GoToTidyUp(3.14Г—3Г—4)вү 3 #.TEMP.MyMath.Times 4
 вҶ’T.GoToTidyUp 1вү вүў#.TEMP.вҺ•NLвҚі16

 rвҶҗT._OK

вҲҶTidyUp:
 {}вҺ•SE.Link.Break'#.TEMP2'
 Assert 0=вҠғF.RmDir dir
 Assert TC.MyUserSettings.RemoveRegistry'[local2]'
 F.DeleteFile toBeDeleted
 #.вҺ•EX TC.GetTatinRootSpace'#'
вҚқDone
