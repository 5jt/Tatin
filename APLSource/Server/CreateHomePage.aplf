 response‚ÜêCreateHomePage request;html;policy;add;regInfo
‚çù Creates the index.html
 add‚Üê''
 html‚ÜêHtmlHeader add
 html,‚Üê‚äÇ'<h2>Main page</h2>'
 html,‚ÜêAddSpecialMessage ‚ç¨
 html,‚Üê‚äÇ'<p>This is the Tatin Registry. It holds packages designed to be used under Dyalog APL.</p>'
 html,‚Üê‚äÇ'<div class="install-info">'
 html,‚Üê‚äÇ'<h3>The Tatin Client</h3>'
 html,‚Üê‚äÇ'<hr>'
 html,‚Üê‚äÇ'<ul>'
 html,‚Üê‚äÇ'<li>How to <a href="./',StaticFolder,'docs/InstallingAndUpdatingTheTatinClient.html" target="_blank" rel=noopener>install</a></li>'
 html,‚Üê‚äÇ'<li>How to <a href="https://tatin.dev/Assets/docs/InstallingAndUpdatingTheTatinClient.html#updating-tatin" target="_blank" rel=noopener>update</a></li>'
 html,‚Üê‚äÇ'</ul>'
 html,‚Üê‚äÇ'</div>'
 html,‚Üê‚äÇ'<nav>'
 html,‚Üê‚äÇ'<ol>'
 regInfo‚ÜêGetRegistryInfo G.INI
 html,‚Üê‚äÇ'<li><a href="',Reg.VersionOf_REST,'/packages">',regInfo,'Packages</a></li>'
 html,‚Üê‚äÇ'<li><a href="',Reg.VersionOf_REST,'/deprecated-pkgs">',regInfo,'Deprecated packages</a></li>'
 html,‚Üê‚äÇ'<li><a href="',Reg.VersionOf_REST,'/groups">',regInfo,'Groups</a></li>'
 html,‚Üê‚äÇ'<li><a href="',Reg.VersionOf_REST,'/tags">',regInfo,'Tags</a></li>'
 html,‚Üê‚äÇ'<li><a href="',Reg.VersionOf_REST,'/documentation">Documentation Center</a></li>'
 html,‚Üê‚äÇ'<li><a href="',Reg.VersionOf_REST,'/credential-report">',regInfo,'Credential report</a></li>'
 html,‚Üê‚äÇ'<li><a href="',Reg.VersionOf_REST,'/usage-data">',regInfo,'Usage data</a></li>'
 :If G.INI.Exist'LICENSE:names'
 :AndIf 0<‚â¢‚äÉG.INI.Get'LICENSE:names'
     html,‚Üê‚äÇ'<li><a href="',Reg.VersionOf_REST,'/get-licenses">Licensing</a></li>'
 :EndIf
 html,‚Üê‚äÇ'<li><a href="',Reg.VersionOf_REST,'/version-information">',regInfo,'Version information</a></li>'
 html,‚Üê‚äÇ'</ol>'
 html,‚Üê‚äÇ'</nav>'
 :Select GetDeletePolicy
 :Case 'Any'
     policy‚Üê'This server operates a "delete any" policy: you may delete <b>any</b> package with fitting credentials.'
 :Case 'None'
     policy‚Üê'This server operates a "delete none" policy: once published, packages cannot be deleted.'
 :Case 'JustBetas'
     policy‚Üê'This server operates a "delete betas only" policy: you may delete <b>only</b> beta packages with fitting credentials.'
 :EndSelect
 html,‚Üê‚äÇ'<p>',policy,'</p>'
 html,‚ÜêGetFooter
 html,‚Üê‚äÇ'</body>'
 html,‚Üê‚äÇ'</html>'
 response‚Üêrequest ReturnHTML html
‚çùDone
