 response‚Üêrequest ProcessTestCommands path
‚çù This function must only be called when G.TestFlag is true
 :If G.INI.Exist'CONFIG:SpecialCommands'
 :AndIf G.INI.Get'CONFIG:SpecialCommands'
     :Select ‚éïC path
     :Case GetVersion_REST'get-server-path'
         response‚ÜêReturnRegistryPath request
     :Case GetVersion_REST'recompile-index'
         Reg.Index.Compile G.RegistryPath
         response‚Üêrequest Respond 200
     :Case GetVersion_REST'stop'
         1 ‚éïSTOP'#.Tatin.Server.OnRequest'
         response‚Üêrequest Respond 200
     :Case GetVersion_REST'list-commands'
         response‚Üêrequest Respond 200
         response.Content‚ÜêPrepareHTMLforAllSpecialCommands ‚ç¨
     :Case GetVersion_REST'set-delete-policy'
         response‚Üêrequest Respond 200
         response.Content‚ÜêGetDeletePolicy
         :If (‚äÇrequest.Content)‚àä'None' 'Any' 'JustBetas'
             (0 1 2)['None' 'Any' 'JustBetas'‚ç≥‚äÇrequest.Content]G.INI.Put'Config:DeletePackages'
         :Else
             response‚Üêrequest Respond 400 1
         :EndIf
     :Case GetVersion_REST'shutdown'
         response‚Üêrequest Respond 200
         ‚àÜSHUTDOWN‚Üê1
     :Case GetVersion_REST'crash'
         ‚àò‚àò‚àò                                ‚çù Deliberate crash for testing error trapping
     :Case GetVersion_REST'off'
         :If A.IsDevelopment
             ‚àò‚àò‚àò                            ‚çù In runtime this would be ‚éïOFF
         :Else
             ‚éïTRAP‚Üê0 'S'
             ‚àò‚àò‚àò
             ‚éïOFF
         :EndIf
     :Case GetVersion_REST'setmusthavelicensefile'
         1 G.INI.Put'CONFIG:MustHaveLicenseFile'
         response‚Üêrequest Respond 200
         response.Content‚Üê'MustHaveLicenseFile=1'
     :Case GetVersion_REST'unsetmusthavelicensefile'
         0 G.INI.Put'CONFIG:MustHaveLicenseFile'
         response‚Üêrequest Respond 200
         response.Content‚Üê'MustHaveLicenseFile=0'
     :Else
         response‚Üêrequest RespondWithHTML 404 'Unknown REST command'
     :EndSelect
 :Else
     response‚Üêrequest RespondWithHTML 404 'Unknown REST command'
 :EndIf
