     Assert F.MkDir parms.to,'/Licenses/Plodder'
     (parms.to,'/Licenses/Plodder/')‚éïNCOPY'Assets/Runtime/Plodder/LICENSE'
     parms.to ‚éïNCOPY'LICENSE'

     ‚éïWSID‚ÜêtargetPath,'/Server/Server'
     #.‚éïEX'Make_'
     'Plodder' 'RumbaLean'#.Tatin.‚éïCY ##.CiderConfig.HOME,'/Assets/Runtime/Plodder/Plodder'
     0 ‚éïSAVE ‚éïWSID

     (targetPath,'/Docker')(‚éïNCOPY‚çÝ('IfExists' 'Replace')F.ExecNfunction)'./Docker/'
